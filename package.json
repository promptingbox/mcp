{
  "name": "@promptingbox/mcp",
  "version": "0.7.0",
  "description": "MCP server for PromptingBox — save, search, and discover prompts from Claude, Cursor, and ChatGPT with AI-powered semantic search",
  "license": "MIT",
  "type": "module",
  "bin": {
    "promptingbox-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./tools": "./dist/tools.js",
    "./api-client": "./dist/api-client.js"
  },
  "files": [
